# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Provider + model selection
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4-turbo
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Pipeline tuning
MAX_GROUP_SIZE=2
PHASE_2_ENABLED=True
PHASE_1_CONFIDENCE=0.66
MATCH_SCORE_THRESHOLD=0.5

# Sampling + concurrency
OPENAI_N=3
OPENAI_TEMPERATURE=1.0
PARALLEL_OPENAI_REQUESTS=5
PARALLEL_ANTHROPIC_REQUESTS=3

# Storage
RESULTS_DIR=thesis-extension/results
TEMPLATE_DIR=thesis-extension/templates

# Set to False for offline mock-mode development
QUERY_LLM=True
